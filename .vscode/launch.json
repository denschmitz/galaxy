{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Galaxy: Validate Pillars Config",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "module": "galaxy.cli",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "validate-config",
        "--config",
        "${workspaceFolder}/examples/pillars.yaml"
      ]
    },
    {
      "name": "Galaxy: Run Pillars Pipeline",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "module": "galaxy.cli",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "run",
        "--config",
        "${workspaceFolder}/examples/pillars.yaml",
        "--workdir",
        "${workspaceFolder}/artifacts/pillars"
      ]
    },
    {
      "name": "Galaxy: Reproduce Pillars",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "module": "galaxy.cli",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "reproduce",
        "--config",
        "${workspaceFolder}/artifacts/pillars/run_config.yaml",
        "--workdir",
        "${workspaceFolder}/artifacts/pillars"
      ]
    },
    {
      "name": "Galaxy: Streamlit UI (Pillars)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "module": "streamlit",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "run",
        "${workspaceFolder}/src/galaxy/ui.py",
        "--",
        "${workspaceFolder}/artifacts/pillars/exported_planes.fits"
      ]
    }
  ]
}
